# =============================================================================
# Gutachten-Manager — Umgebungsvariablen (Vorlage)
# =============================================================================
#
# ERSTSTART:
#   1. cp .env.example .env
#   2. Alle Pflichtfelder befuellen (insbesondere DATABASE_PASSWORD)
#   3. docker compose down -v && docker compose up --build -d
#
# NACH AENDERUNG VON DATABASE_USER ODER DATABASE_PASSWORD:
#   docker compose down -v && docker compose up --build -d
#   (PostgreSQL initialisiert das Volume neu — bestehende Daten gehen verloren)
#
# NORMALER NEUSTART (Daten bleiben):
#   docker compose up --build -d
#
# .env NIEMALS in Git einchecken!
# =============================================================================

# -----------------------------------------------------------------------------
# Datenbank (PostgreSQL) — PFLICHTFELDER
# Alle drei Werte muessen gesetzt sein, sonst verweigert docker compose den Start.
# -----------------------------------------------------------------------------
DATABASE_NAME=gutachten_manager
DATABASE_USER=gutachten_user
DATABASE_PASSWORD=<SICHERES_PASSWORT_HIER_EINTRAGEN>

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
LOG_LEVEL=info
CORS_ORIGINS=http://localhost
MAX_UPLOAD_SIZE_MB=50

# -----------------------------------------------------------------------------
# Backup-System
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_SCHEDULE=0 2 * * *
