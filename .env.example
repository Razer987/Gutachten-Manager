# =============================================================================
# Gutachten-Manager — Umgebungsvariablen (Vorlage)
# =============================================================================
# ANLEITUNG:
#   1. Diese Datei nach ".env" kopieren: cp .env.example .env
#   2. Alle Werte mit sicheren Passwörtern befüllen
#   3. .env NIE in Git einchecken!
# =============================================================================

# -----------------------------------------------------------------------------
# Datenbank (PostgreSQL) — PFLICHTFELDER
# -----------------------------------------------------------------------------
DATABASE_NAME=gutachten_manager
DATABASE_USER=gutachten_user
DATABASE_PASSWORD=<SICHERES_PASSWORT_HIER_EINTRAGEN>

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGINS=http://localhost
MAX_UPLOAD_SIZE_MB=50

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# -----------------------------------------------------------------------------
# Backup-System
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_SCHEDULE=0 2 * * *
