# =============================================================================
# .env.example — Gutachten-Manager
# =============================================================================
# Verwendung:
#   cp .env.example .env
#   # DATABASE_PASSWORD setzen
#   docker compose up --build -d
#
# Nach Änderung von POSTGRES_USER oder POSTGRES_PASSWORD:
#   docker compose down -v && docker compose up --build -d
#   (Volume-Reset erforderlich — PostgreSQL ignoriert geänderte Credentials
#    bei bestehendem Datenverzeichnis)
#
# .env NIEMALS committen!
# =============================================================================

# Datenbank — alle drei Werte werden direkt von PostgreSQL und Prisma genutzt
POSTGRES_USER=gutachten_user
POSTGRES_PASSWORD=<SICHERES_PASSWORT_HIER_EINTRAGEN>
POSTGRES_DB=gutachten_manager

# Optional — Defaults sind für lokalen Betrieb ausreichend
CORS_ORIGINS=http://localhost
LOG_LEVEL=info
MAX_UPLOAD_SIZE_MB=50
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_SCHEDULE=0 2 * * *
