# API-spezifische Umgebungsvariablen
# Kopieren: cp .env.example .env.local
# Für vollständige Dokumentation: ../../.env.example

NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://dev:dev_password@localhost:5432/gutachten_manager?schema=public
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
LOG_LEVEL=debug
LOG_DIR=./logs
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_SCHEDULE=0 2 * * *
