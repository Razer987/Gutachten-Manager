# =============================================================================
# Gutachten-Manager — Umgebungsvariablen
# =============================================================================
#
# ERSTSTART:
#   1. cp .env.example .env
#   2. DATABASE_PASSWORD setzen
#   3. docker compose up --build -d
#
# NACH ÄNDERUNG VON DATABASE_USER ODER DATABASE_PASSWORD:
#   docker compose down -v && docker compose up --build -d
#   (PostgreSQL-Volume wird zurückgesetzt — bestehende Daten gehen verloren)
#
# .env NIEMALS in Git einchecken!
# =============================================================================

# -----------------------------------------------------------------------------
# Datenbank — PFLICHTFELDER (alle drei müssen gesetzt sein)
# -----------------------------------------------------------------------------
DATABASE_NAME=gutachten_manager
DATABASE_USER=gutachten_user
DATABASE_PASSWORD=<SICHERES_PASSWORT_HIER_EINTRAGEN>

# -----------------------------------------------------------------------------
# API (optional — Defaults in docker-compose.yml ausreichend für lokalen Betrieb)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost
LOG_LEVEL=info
MAX_UPLOAD_SIZE_MB=50

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=/api/v1

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_SCHEDULE=0 2 * * *
