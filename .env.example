# =============================================================================
# Umgebungsvariablen — Gutachten-Manager
# =============================================================================
# ANLEITUNG FÜR NEUE ENTWICKLER:
#   1. Diese Datei kopieren: cp .env.example .env
#   2. Alle Werte mit <WERT_HIER_EINTRAGEN> durch echte Werte ersetzen
#   3. Die .env Datei NIEMALS in Git committen!
#
# WICHTIG: Alle Variablen ohne Standardwert (gekennzeichnet mit <...>)
#          MÜSSEN vor dem Start gesetzt werden.
# =============================================================================

# -----------------------------------------------------------------------------
# Datenbank (PostgreSQL)
# -----------------------------------------------------------------------------
# Host der PostgreSQL-Instanz (bei Docker: "db")
DATABASE_HOST=localhost

# Port der PostgreSQL-Instanz (Standard: 5432)
DATABASE_PORT=5432

# Name der Hauptdatenbank
DATABASE_NAME=gutachten_manager

# Datenbankbenutzer
DATABASE_USER=<DATENBANK_BENUTZER>

# Datenbankpasswort (sicheres Passwort wählen!)
DATABASE_PASSWORD=<SICHERES_PASSWORT>

# Vollständige Prisma Connection-URL (wird aus den obigen Werten zusammengesetzt)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=public

# -----------------------------------------------------------------------------
# API Server (Express.js)
# -----------------------------------------------------------------------------
# Port auf dem der API-Server läuft
API_PORT=4000

# Umgebung: "development", "production", "test"
NODE_ENV=development

# CORS: Erlaubte Frontend-Origins (kommagetrennt)
CORS_ORIGINS=http://localhost:3000

# Maximale Upload-Dateigröße in Megabyte
MAX_UPLOAD_SIZE_MB=50

# Pfad zum Upload-Verzeichnis (relativ zum api/ Verzeichnis)
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
# Port auf dem das Frontend läuft
NEXT_PUBLIC_PORT=3000

# URL der API (vom Browser aus erreichbar)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# URL der API (vom Server/Docker aus erreichbar — intern)
INTERNAL_API_URL=http://api:4000/api/v1

# -----------------------------------------------------------------------------
# Backup-System
# -----------------------------------------------------------------------------
# Verzeichnis für automatische Backups
BACKUP_DIR=./backups

# Backup-Aufbewahrungszeit in Tagen (ältere Backups werden gelöscht)
BACKUP_RETENTION_DAYS=30

# Uhrzeit für automatisches Backup (Cron-Format: "0 2 * * *" = täglich 02:00 Uhr)
BACKUP_CRON_SCHEDULE=0 2 * * *

# -----------------------------------------------------------------------------
# Logging (Winston)
# -----------------------------------------------------------------------------
# Log-Level: "error", "warn", "info", "debug"
LOG_LEVEL=info

# Verzeichnis für Log-Dateien
LOG_DIR=./logs

# -----------------------------------------------------------------------------
# Feature Flags (Admin-Panel verwaltet diese zur Laufzeit)
# Hier können Features initial aktiviert/deaktiviert werden.
# -----------------------------------------------------------------------------
FEATURE_KALENDER=true
FEATURE_FOTO_EDITOR=true
FEATURE_SKIZZEN=true
FEATURE_PDF_EXPORT=true
FEATURE_VOLLTEXTSUCHE=true
FEATURE_MULTI_TENANCY=false
