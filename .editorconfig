# =============================================================================
# EditorConfig — Gutachten-Manager
# =============================================================================
# Sorgt für konsistente Code-Formatierung über alle Editoren und IDEs hinweg.
# Unterstützt von: VS Code, IntelliJ, Vim, Emacs, Sublime Text und vielen mehr.
# Mehr Infos: https://editorconfig.org
# =============================================================================

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.{ts,tsx,js,jsx,json,yaml,yml,css,scss,md}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{sh,bash}]
end_of_line = lf
